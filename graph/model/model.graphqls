type IngredientCategory {
  id: Int64!
  name: String!
  unit: String!
  convert_unit: String
  status: Boolean!
  deleted_at: Time
  created_at: Time!
  updated_at: Time!
}

type Ingredient {
  id: Int64!
  name: String!
  category_id: Int64
  category: IngredientCategory
  is_active: Boolean!
  deleted_at: Time
  created_at: Time!
  updated_at: Time!
}