type AuthResponse {
  code: Int!
  success: Boolean!
  message: String!
  data: AuthData
}

# Pagination metadata type
type PageInfo {
  current_page: Int!
  per_page: Int!
  total_items: Int!
  total_pages: Int!
  has_next_page: Boolean!
  has_previous_page: Boolean!
  start_item: Int
  end_item: Int
}

type AuthData {
  token: String!
  user: User!
}

